---
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

const isHome = path === base;
const isLab = path.startsWith(`${base}lab`);
const isDocs = path.startsWith(`${base}docs`);
---

<header class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
    <div class="container-fluid">
        <a class="navbar-brand fw-semibold" href={base}>MyOshi Theme Lab</a>

        <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#siteNav"
                aria-controls="siteNav"
                aria-expanded="false"
                aria-label="Toggle navigation"
        >
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="siteNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class={`nav-link ${isHome ? 'active' : ''}`} href={base} aria-current={isHome ? 'page' : undefined}>Home</a>
                </li>
                <li class="nav-item">
                    <a class={`nav-link ${isLab ? 'active' : ''}`} href={`${base}lab/`} aria-current={isLab ? 'page' : undefined}>Lab</a>
                </li>
                <li class="nav-item">
                    <a class={`nav-link ${isDocs ? 'active' : ''}`} href={`${base}docs/`} aria-current={isDocs ? 'page' : undefined}>Docs</a>
                </li>
            </ul>

            <a class="btn btn-sm btn-outline-light" href="https://github.com/crimsonstrife/oshi-lab" target="_blank" rel="noopener">
                GitHub
            </a>
        </div>
    </div>
</header>