---
import Icon from "./ui/Icon.astro";

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const version = import.meta.env.PUBLIC_APP_VERSION;
---

<footer class="border-top bg-body mt-auto">
    <div class="container-fluid py-4">
        <div class="row g-4 align-items-start">
            <div class="col-12 col-lg-5">
                <div class="fw-semibold d-flex align-items-center gap-2">
                    <Icon name="fa-solid fa-flask" title="Theme Lab" />
                    <span>MyOshi Theme Lab</span>
                </div>
                <p class="text-body-secondary small mt-2 mb-3">
                    Build, preview, and share clean MyOshi profile themes with reusable UI patterns.
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-sm btn-outline-secondary" href="https://github.com/crimsonstrife/oshi-lab" target="_blank" rel="noopener">
                        <Icon name="fa-brands fa-github" title="GitHub" /> <span class="ms-2">Repo</span>
                    </a>
                    <a class="btn btn-sm btn-outline-secondary" href="https://github.com/crimsonstrife/oshi-lab/issues" target="_blank" rel="noopener">
                        <Icon name="fa-solid fa-bug" title="Issues" /> <span class="ms-2">Issues</span>
                    </a>
                    <a class="btn btn-sm btn-outline-secondary" href="https://github.com/crimsonstrife/oshi-lab/discussions" target="_blank" rel="noopener">
                        <Icon name="fa-solid fa-comments" title="Discussions" /> <span class="ms-2">Discussions</span>
                    </a>
                </div>
            </div>

            <div class="col-6 col-lg-2">
                <div class="text-uppercase small fw-semibold mb-2">Site</div>
                <ul class="list-unstyled small mb-0 d-grid gap-1">
                    <li><a class="link-secondary" href={`${base}lab/`}>Lab</a></li>
                    <li><a class="link-secondary" href={`${base}docs/`}>Docs</a></li>
                    <li><a class="link-secondary" href={`${base}`}>Home</a></li>
                </ul>
            </div>

            <div class="col-6 col-lg-2">
                <div class="text-uppercase small fw-semibold mb-2">Resources</div>
                <ul class="list-unstyled small mb-0 d-grid gap-1">
                    <li><a class="link-secondary" href="https://github.com/crimsonstrife/oshi-lab/releases" target="_blank" rel="noopener">Releases</a></li>
                    <li><a class="link-secondary" href="https://github.com/crimsonstrife/oshi-lab/blob/production/README.md" target="_blank" rel="noopener">README</a></li>
                    <li><a class="link-secondary" href="https://github.com/crimsonstrife/oshi-lab/blob/production/LICENSE" target="_blank" rel="noopener">License</a></li>
                </ul>
            </div>

            <div class="col-12 col-lg-3">
                <div class="text-uppercase small fw-semibold mb-2">Creator</div>
                <div class="small text-body-secondary">
                    Made with <Icon name="fa-solid fa-heart" title="Love" /> by{" "}
                    <a class="link-secondary" href="https://crimsonstrife.live" target="_blank" rel="noopener">CrimsonStrife</a>
                    {version ? <span class="ms-2">• v{version}</span> : null}
                </div>

                <div class="d-flex gap-3 mt-2">
                    <a class="link-secondary" href="https://github.com/crimsonstrife/oshi-lab" target="_blank" rel="noopener" aria-label="GitHub">
                        <Icon name="fa-brands fa-github" title="GitHub" label="GitHub" />
                    </a>
                    <a class="link-secondary" href="https://crimsonstrife.live" target="_blank" rel="noopener" aria-label="Website">
                        <Icon name="fa-solid fa-link" title="Website" label="Author's Website"/>
                    </a>
                    <a class="link-secondary" href="#top" aria-label="Back to top" title="Back to top">
                        <Icon name="fa-solid fa-arrow-up" title="Back to top" />
                    </a>
                </div>
            </div>
        </div>

        <hr class="my-4" />

        <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
            <div class="text-body-secondary small">© {year} MyOshi Theme Lab</div>
            <div class="small d-flex gap-3">
                {/* <a class="link-secondary" href={`${base}privacy/`}>Privacy</a> */}
                {/* <a class="link-secondary" href={`${base}terms/`}>Terms</a> */}
            </div>
        </div>
    </div>
</footer>