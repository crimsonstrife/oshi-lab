---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="border-top bg-body">
    <div class="container-fluid py-3 d-flex flex-wrap gap-2 justify-content-between align-items-center">
        <div class="text-body-secondary small">
            © {year} MyOshi Theme Lab
        </div>
        <div class="d-flex gap-3 small">
            <a class="link-secondary" href={`${base}docs/`}>Docs</a>
            <a class="link-secondary" href={`${base}lab/`}>Lab</a>
            <a class="link-secondary" href="https://github.com/crimsonstrife/oshi-lab" target="_blank" rel="noopener">GitHub</a>
        </div>
    </div>
</footer>