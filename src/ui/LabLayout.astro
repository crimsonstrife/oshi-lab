---
import AppLayout from './AppLayout.astro';

const { title, fullBleed = false } = Astro.props;
---

<AppLayout
        title={title}
        bodyClass={fullBleed ? 'lab-fullbleed' : 'lab'}
        mainClass={fullBleed ? 'flex-grow-1 p-0' : 'flex-grow-1'}
        extraStyles={['/styles/lab.css']}
>
    <slot />
</AppLayout>