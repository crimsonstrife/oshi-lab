---
import AppLayout from "../ui/AppLayout.astro";
import { getCollection } from "astro:content";

const page = {
  title: "Known Issues",
  description:
    "A running list of known issues and limitations across MyOshi Theme Lab, plus workarounds and reporting tips.",
};

const severityMeta = {
  impacting: { label: "Impacting", badge: "text-bg-danger" },
  annoying: { label: "Annoying", badge: "text-bg-warning" },
  note: { label: "Note", badge: "text-bg-secondary" },
};

const severityOrder = { impacting: 0, annoying: 1, note: 2 };

function join(arr) {
  return (arr || []).join(", ");
}

function fmtDate(d) {
  try {
    return new Intl.DateTimeFormat("en-US", { year: "numeric", month: "short", day: "2-digit" }).format(d);
  } catch {
    return d.toISOString().slice(0, 10);
  }
}

// Load from content collection
const entries = await getCollection("known-issues");

// Hide resolved by default
const openEntries = entries.filter((e) => !e.data.resolved);

// Normalize shape for rendering
const issues = openEntries
  .map((e) => ({
    id: e.slug, // anchors and quick-links
    ...e.data,
  }))
  .sort((a, b) => {
    const sa = severityOrder[a.severity] ?? 99;
    const sb = severityOrder[b.severity] ?? 99;
    if (sa !== sb) return sa - sb;

    const oa = a.order ?? 0;
    const ob = b.order ?? 0;
    if (oa !== ob) return oa - ob;

    const da = a.updated ? new Date(a.updated).getTime() : 0;
    const db = b.updated ? new Date(b.updated).getTime() : 0;
    if (da !== db) return db - da;

    return String(a.title).localeCompare(String(b.title));
  });

// Page "last updated" = max(updated) among open issues
const lastUpdated = issues.reduce((max, i) => {
  const t = i.updated ? new Date(i.updated).getTime() : 0;
  return Math.max(max, t);
}, 0);

const lastUpdatedText = lastUpdated ? fmtDate(new Date(lastUpdated)) : "—";
---

<AppLayout title="Known Issues" bodyClass="known-issues">
  <main class="container py-4">
    <div id="top"></div>

    <header class="mb-4">
      <h1 class="mb-2">{page.title}</h1>
      <p class="text-muted mb-2">{page.description}</p>

      <div class="d-flex flex-wrap gap-2 align-items-center">
        <span class="badge text-bg-dark">Last updated: {lastUpdatedText}</span>
        <span class="badge text-bg-info">Total open: {issues.length}</span>
      </div>
    </header>

    <section class="mb-4">
      <div class="alert alert-secondary" role="note">
        If you’re seeing something that’s <strong>not</strong> listed here, please report it (steps below).
        This page is for <em>confirmed</em> issues and platform limitations.
      </div>
    </section>

    <section class="mb-4">
      <h2 class="h4">Quick links</h2>
      <div class="row g-2">
        {issues.map((i) => (
          <div class="col-12 col-md-6 col-lg-4">
            <a class="d-block text-decoration-none border rounded p-2" href={`#${i.id}`}>
              <div class="d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">{i.title}</span>
                <span class={`badge ${severityMeta[i.severity]?.badge ?? "text-bg-secondary"}`}>
                  {severityMeta[i.severity]?.label ?? i.severity}
                </span>
              </div>
              <div class="small text-muted mt-1">{join(i.areas)} • {i.status}</div>
            </a>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-5">
      <h2 class="h4 mb-3">Issues</h2>

      {issues.length === 0 ? (
        <div class="alert alert-success" role="note">
          No known issues are currently listed.
        </div>
      ) : (
        <div class="accordion" id="knownIssuesAccordion">
          {issues.map((i, idx) => (
            <div class="accordion-item" id={i.id}>
              <h3 class="accordion-header" id={`heading-${i.id}`}>
                <button
                  class={`accordion-button ${idx === 0 ? "" : "collapsed"}`}
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target={`#collapse-${i.id}`}
                  aria-expanded={idx === 0 ? "true" : "false"}
                  aria-controls={`collapse-${i.id}`}
                >
                  <span class="me-2">{i.title}</span>
                  <span class={`badge ms-auto ${severityMeta[i.severity]?.badge ?? "text-bg-secondary"}`}>
                    {severityMeta[i.severity]?.label ?? i.severity}
                  </span>
                </button>
              </h3>

              <div
                id={`collapse-${i.id}`}
                class={`accordion-collapse collapse ${idx === 0 ? "show" : ""}`}
                aria-labelledby={`heading-${i.id}`}
                data-bs-parent="#knownIssuesAccordion"
              >
                <div class="accordion-body">
                  <div class="mb-2 d-flex flex-wrap gap-2">
                    <span class="badge text-bg-dark">Status: {i.status}</span>
                    <span class="badge text-bg-secondary">Areas: {join(i.areas)}</span>
                    {i.updated ? <span class="badge text-bg-light text-dark">Updated: {fmtDate(new Date(i.updated))}</span> : null}
                  </div>

                  {i.details?.length ? (
                    <>
                      <h4 class="h6 mt-3">What’s happening</h4>
                      <ul>
                        {i.details.map((d) => <li>{d}</li>)}
                      </ul>
                    </>
                  ) : null}

                  {i.workaround?.length ? (
                    <>
                      <h4 class="h6 mt-3">Workaround</h4>
                      <ul>
                        {i.workaround.map((w) => <li>{w}</li>)}
                      </ul>
                    </>
                  ) : null}

                  {i.snippet ? (
                    <>
                      <h4 class="h6 mt-3">Snippet</h4>
                      <pre class="bg-body-tertiary p-2 rounded mb-0"><code>{i.snippet}</code></pre>
                    </>
                  ) : null}

                  <div class="mt-3">
                    <a class="small" href="#top">Back to top</a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>

    <section class="mb-5">
      <h2 class="h4">How to report an issue</h2>
      <p class="text-muted">
        If you encounter a bug that isn’t listed above, please include as much of the following as you can.
        It saves a lot of back-and-forth and makes fixes faster.
      </p>

      <div class="row g-3">
        <div class="col-12 col-lg-6">
          <div class="border rounded p-3 h-100">
            <h3 class="h6">Include</h3>
            <ul class="mb-0">
              <li>What you expected vs what happened</li>
              <li>Steps to reproduce (click-by-click)</li>
              <li>Your browser + version (Chrome/Firefox/Safari) and OS</li>
              <li>A minimal CSS/HTML sample that triggers it (if possible)</li>
              <li>Audit report JSON (use “Copy JSON” in the Audit tab)</li>
            </ul>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="border rounded p-3 h-100">
            <h3 class="h6">Avoid sharing</h3>
            <ul class="mb-0">
              <li>Personal info (emails, private links)</li>
              <li>Private tokens/keys</li>
              <li>Unredacted DMs or private server info</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="alert alert-info mt-3" role="note">
        Tip: When possible, reduce the theme to the smallest snippet that still reproduces the issue. It makes debugging dramatically easier.
      </div>
    </section>

    <footer class="border-top pt-3 text-muted small">
      <p class="mb-0">
        Link this page in announcements: <code>/known-issues</code>
      </p>
    </footer>
  </main>
</AppLayout>
