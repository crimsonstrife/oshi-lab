---
import AppLayout from '../ui/AppLayout.astro';

const effectiveDate = "February 25, 2026";
const base = import.meta.env.BASE_URL;
---

<AppLayout title="Terms of Service">
  <main id="main" class="container py-5">
    <h1 class="mb-2">Terms of Service</h1>
    <p class="text-body-secondary small mb-4">Effective date: {effectiveDate}</p>

    <div class="vstack gap-4" style="max-width: 60rem;">
      <section>
        <p>
          These Terms of Service ("Terms") govern your access to and use of Oshi‑Lab (the "Service"). By using the Service,
          you agree to these Terms.
        </p>
      </section>

      <section>
        <h2 class="h4">What the Service is</h2>
        <p class="mb-0">
          Oshi‑Lab is a browser-based sandbox for drafting and previewing MyOshi Custom CSS and Custom HTML. The preview is
          sandboxed and scripts are blocked.
        </p>
      </section>

      <section>
        <h2 class="h4">No affiliation</h2>
        <p class="mb-0">
          Oshi‑Lab is an independent project and is not affiliated with, endorsed by, or sponsored by MyOshi. Any third-party
          names or trademarks are the property of their respective owners.
        </p>
      </section>

      <section>
        <h2 class="h4">Your content</h2>
        <ul>
          <li>
            <strong>You retain ownership</strong> of the CSS/HTML you create.
          </li>
          <li>
            You are responsible for the content you paste into MyOshi or share elsewhere.
          </li>
          <li>
            Do not paste secrets (passwords, API keys) into the editor.
          </li>
        </ul>
      </section>

      <section>
        <h2 class="h4">Acceptable use</h2>
        <p>When using Oshi‑Lab, you agree not to:</p>
        <ul>
          <li>Use the Service to violate any applicable law or third-party rights.</li>
          <li>Attempt to disrupt, probe, or overload the Service or its hosting.</li>
          <li>Use the Service to distribute malware or malicious content.</li>
        </ul>
      </section>

      <section>
        <h2 class="h4">Open-source code and contributions</h2>
        <p class="mb-0">
          The Service is open-source. Your use of the source code is governed by the repository’s LICENSE file. If you submit
          contributions (e.g., pull requests), you agree they may be used and redistributed under the same license.
        </p>
      </section>

      <section>
        <h2 class="h4">Availability and changes</h2>
        <p class="mb-0">
          I may change, suspend, or discontinue any part of the Service at any time, with or without notice.
        </p>
      </section>

      <section>
        <h2 class="h4">Disclaimer</h2>
        <p class="mb-0">
          The Service is provided “as is” and “as available,” without warranties of any kind, express or implied, including
          fitness for a particular purpose and non-infringement. You use the Service at your own risk.
        </p>
      </section>

      <section>
        <h2 class="h4">Limitation of liability</h2>
        <p class="mb-0">
          To the fullest extent permitted by law, I am not liable for any indirect, incidental, special, consequential, or
          punitive damages, or any loss of data, profits, or revenues, arising from your use of the Service.
        </p>
      </section>

      <section>
        <h2 class="h4">Privacy</h2>
        <p class="mb-0">
          Our <a href={`${base}privacy/`}>Privacy Policy</a> explains how the Service handles data.
        </p>
      </section>

      <section>
        <h2 class="h4">Contact</h2>
        <p class="mb-0">
          Questions about these Terms? Open an issue in the repository:
          <a href="https://github.com/crimsonstrife/oshi-lab" target="_blank" rel="noopener">github.com/crimsonstrife/oshi-lab</a>
        </p>
      </section>
    </div>
  </main>
</AppLayout>
